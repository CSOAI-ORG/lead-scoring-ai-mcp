{
  "name": "lead-scoring-ai-mcp",
  "description": "Lead Scoring Ai tools for AI agents. Capabilities: score lead, add lead, update lead activity. Built by MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "score_lead",
      "description": "Score a lead based on firmographic data",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          },
          "company_size": {
            "type": "integer"
          },
          "budget": {
            "type": "number"
          },
          "engagement_score": {
            "type": "number"
          },
          "has_decision_maker_contact": {
            "type": "boolean"
          },
          "email_verified": {
            "type": "boolean"
          },
          "website_traffic_monthly": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "add_lead",
      "description": "Add a new lead to tracking",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "contact_name": {
            "type": "string"
          },
          "contact_email": {
            "type": "string"
          },
          "company_size": {
            "type": "integer"
          },
          "industry": {
            "type": "string"
          }
        },
        "required": [
          "lead_id",
          "company_name"
        ]
      }
    },
    {
      "name": "update_lead_activity",
      "description": "Record lead activity",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          },
          "activity_type": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "lead_id",
          "activity_type"
        ]
      }
    },
    {
      "name": "get_lead_score",
      "description": "Get current score for a lead",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          }
        },
        "required": [
          "lead_id"
        ]
      }
    },
    {
      "name": "get_all_leads",
      "description": "Get all leads with scores",
      "parameters": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_lead_activities",
      "description": "Get activity history for a lead",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          }
        },
        "required": [
          "lead_id"
        ]
      }
    },
    {
      "name": "get_lead_timeline",
      "description": "Get engagement timeline for a lead",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          }
        },
        "required": [
          "lead_id"
        ]
      }
    },
    {
      "name": "predict_conversion",
      "description": "Predict conversion probability",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          }
        },
        "required": [
          "lead_id"
        ]
      }
    },
    {
      "name": "get_priority_leads",
      "description": "Get leads by priority threshold",
      "parameters": {
        "type": "object",
        "properties": {
          "min_score": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": []
      }
    },
    {
      "name": "track_engagement_trend",
      "description": "Get engagement trend over time",
      "parameters": {
        "type": "object",
        "properties": {
          "lead_id": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          }
        },
        "required": [
          "lead_id"
        ]
      }
    }
  ]
}